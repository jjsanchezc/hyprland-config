#!/usr/bin/env bash
# Auto-restart AGS when source files change
AGS_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/ags"
INSTANCE="jjsanchezc-shell"
LOG="/tmp/ags-watch.log"

start_ags() {
    for i in 1 2 3 4 5; do
        pkill -f "ags run" 2>/dev/null
        ags quit -i "$INSTANCE" 2>/dev/null
        sleep 1
        ags run >> "$LOG" 2>&1 &
        sleep 5
        if ags list 2>/dev/null | grep -q "$INSTANCE"; then
            echo "[$(date)] AGS started (attempt $i)" >> "$LOG"
            # Re-aplicar wallpaper solo si hyprpaper no tiene uno activo (race condition al boot)
            LAST_WP="${XDG_CACHE_HOME:-$HOME/.cache}/current-wallpaper"
            if [[ -f "$LAST_WP" ]]; then
                wp="$(cat "$LAST_WP")"
                if ! hyprctl hyprpaper listactive 2>/dev/null | grep -q "/"; then
                    hyprctl hyprpaper preload "$wp" 2>/dev/null
                    hyprctl hyprpaper wallpaper ",$wp" 2>/dev/null
                    echo "[$(date)] Wallpaper re-applied (hyprpaper had none active): $wp" >> "$LOG"
                else
                    echo "[$(date)] Wallpaper already active, skipping re-apply" >> "$LOG"
                fi
            fi
            return 0
        fi
        echo "[$(date)] AGS failed to start (attempt $i)" >> "$LOG"
    done
    echo "[$(date)] AGS failed after 5 attempts" >> "$LOG"
    return 1
}

start_ags

while inotifywait -r -e modify,create,delete \
    --include '\.(ts|tsx|scss|css)$' "$AGS_DIR" 2>/dev/null; do
    sleep 0.5
    ags quit -i "$INSTANCE" 2>/dev/null
    start_ags
done
